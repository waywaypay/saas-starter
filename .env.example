# ---- Required (app fails fast at runtime if any are missing/invalid) ----
# Postgres connection string
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/socialos"

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET="dev-only-secret-change-me-please-32b"

# Canonical app URL. In production Render derives this; locally set explicitly.
AUTH_URL="http://localhost:3000"

# Shared secret guarding POST /api/cron/sync
CRON_SECRET="dev-cron-secret-change-me"

# ---- Optional ----
# Google OAuth (enables the Google sign-in button when both are set)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# 32-byte hex key for encrypting platform access tokens at rest (AES-256-GCM).
# REQUIRED once any real (non-mock) provider is enabled. Generate with:
#   openssl rand -hex 32
# ENCRYPTION_KEY=""

# Set during `next build` / lint to skip runtime env validation.
# SKIP_ENV_VALIDATION="1"
